{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "currentHouseholdId": { "type": "string", "description": "ID of the currently active household" },
        "stats": {
          "type": "object",
          "properties": {
            "itemsConsumed": { "type": "number" },
            "itemsWasted": { "type": "number" },
            "co2Saved": { "type": "number" },
            "waterSaved": { "type": "number" },
            "currentStreak": { "type": "number" },
            "bestStreak": { "type": "number" },
            "lastActionDate": { "type": "string", "nullable": true },
            "badges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "icon": { "type": "string" },
                  "unlockedAt": { "type": "number" }
                }
              }
            }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Household": {
      "title": "Household",
      "description": "A shared pantry/household",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of user UIDs who have access to this household"
        }
      },
      "required": ["name", "ownerId", "members"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the pantry",
      "type": "object",
      "properties": {
        "householdId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date" },
        "location": { "type": "string", "enum": ["frigorifero", "freezer", "dispensa"], "description": "Physical location of the product" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["householdId", "name", "quantity", "unit", "location"]
    },
    "ShoppingItem": {
      "title": "ShoppingItem",
      "description": "An item on the shopping list",
      "type": "object",
      "properties": {
        "householdId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "isChecked": { "type": "boolean" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["householdId", "name", "quantity", "unit", "isChecked"]
    },
    "SavedRecipe": {
      "title": "SavedRecipe",
      "description": "A recipe saved by the user",
      "type": "object",
      "properties": {
        "householdId": { "type": "string" },
        "title": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "prepTime": { "type": "string" },
        "servings": { "type": "number" },
        "nutritionalValues": {
          "type": "object",
          "properties": {
            "calories": { "type": "number" },
            "protein": { "type": "number" },
            "carbs": { "type": "number" },
            "fat": { "type": "number" }
          }
        },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["householdId", "title", "ingredients", "instructions"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "households/{householdId}": {
      "schema": { "$ref": "#/entities/Household" },
      "description": "Shared households"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Pantry products"
    },
    "shoppingList/{itemId}": {
      "schema": { "$ref": "#/entities/ShoppingItem" },
      "description": "Shopping list items"
    },
    "savedRecipes/{recipeId}": {
      "schema": { "$ref": "#/entities/SavedRecipe" },
      "description": "Saved recipes"
    }
  }
}
