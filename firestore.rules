rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }
    
    function isHouseholdMember(householdId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/households/$(householdId)) &&
             request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == userId &&
               data.email is string && data.email.size() > 0 &&
               (!('displayName' in data) || isValidString(data.displayName, 0, 100)) &&
               (!('currentHouseholdId' in data) || data.currentHouseholdId is string) &&
               (!('moneySaved' in data) || data.moneySaved is number) &&
               (!('co2Saved' in data) || data.co2Saved is number) &&
               (!('stats' in data) || data.stats is map);
      }
      
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    // ===============================================================
    // Households Collection
    // ===============================================================
    match /households/{householdId} {
      function isValidHousehold(data) {
        return data.keys().hasAll(['name', 'ownerId', 'members']) &&
               isValidString(data.name, 1, 100) &&
               data.ownerId is string &&
               data.members is list && data.members.size() > 0 && data.members.size() <= 20;
      }
      
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated() && isValidHousehold(request.resource.data) &&
                    request.resource.data.ownerId == request.auth.uid &&
                    request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.members &&
                    isValidHousehold(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId; // Owner cannot be changed by regular update
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // ===============================================================
    // Products Collection
    // ===============================================================
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['householdId', 'name', 'quantity', 'unit', 'location']) &&
               data.householdId is string &&
               isValidString(data.name, 1, 100) &&
               (!('category' in data) || isValidString(data.category, 0, 50)) &&
               data.quantity is number && data.quantity >= 0 &&
               isValidString(data.unit, 1, 20) &&
               (!('expirationDate' in data) || data.expirationDate is string) &&
               data.location in ['frigorifero', 'freezer', 'dispensa'] &&
               (!('addedAt' in data) || data.addedAt is string);
      }
      
      allow read: if isHouseholdMember(resource.data.householdId);
      allow create: if isHouseholdMember(request.resource.data.householdId) && isValidProduct(request.resource.data);
      allow update: if isHouseholdMember(resource.data.householdId) && 
                    isHouseholdMember(request.resource.data.householdId) && 
                    isValidProduct(request.resource.data) &&
                    request.resource.data.householdId == resource.data.householdId; // Cannot move product between households
      allow delete: if isHouseholdMember(resource.data.householdId);
    }

    // ===============================================================
    // Shopping List Collection
    // ===============================================================
    match /shoppingList/{itemId} {
      function isValidShoppingItem(data) {
        return data.keys().hasAll(['householdId', 'name', 'quantity', 'unit', 'isChecked']) &&
               data.householdId is string &&
               isValidString(data.name, 1, 100) &&
               data.quantity is number && data.quantity >= 0 &&
               isValidString(data.unit, 1, 20) &&
               data.isChecked is bool &&
               (!('addedAt' in data) || data.addedAt is string);
      }
      
      allow read: if isHouseholdMember(resource.data.householdId);
      allow create: if isHouseholdMember(request.resource.data.householdId) && isValidShoppingItem(request.resource.data);
      allow update: if isHouseholdMember(resource.data.householdId) && 
                    isHouseholdMember(request.resource.data.householdId) && 
                    isValidShoppingItem(request.resource.data) &&
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if isHouseholdMember(resource.data.householdId);
    }

    // ===============================================================
    // Saved Recipes Collection
    // ===============================================================
    match /savedRecipes/{recipeId} {
      function isValidSavedRecipe(data) {
        return data.keys().hasAll(['householdId', 'title', 'ingredients', 'instructions']) &&
               data.householdId is string &&
               isValidString(data.title, 1, 200) &&
               data.ingredients is list && data.ingredients.size() <= 50 &&
               data.instructions is list && data.instructions.size() <= 50 &&
               (!('prepTime' in data) || isValidString(data.prepTime, 0, 50)) &&
               (!('servings' in data) || data.servings is number && data.servings > 0) &&
               (!('nutritionalValues' in data) || data.nutritionalValues is map) &&
               (!('savedAt' in data) || data.savedAt is string);
      }
      
      allow read: if isHouseholdMember(resource.data.householdId);
      allow create: if isHouseholdMember(request.resource.data.householdId) && isValidSavedRecipe(request.resource.data);
      allow update: if isHouseholdMember(resource.data.householdId) && 
                    isHouseholdMember(request.resource.data.householdId) && 
                    isValidSavedRecipe(request.resource.data) &&
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if isHouseholdMember(resource.data.householdId);
    }
  }
}
